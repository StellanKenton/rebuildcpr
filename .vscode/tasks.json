{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Firmware: Configure",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/cmake_configure.sh",
      "args": [
        "${workspaceFolder}",
        "${workspaceFolder}/build/Debug",
        "Ninja",
        "${workspaceFolder}/cmake/toolchains/arm-none-eabi.cmake",
        "${config:cpr.tools.armToolchainBinDir}",
        "Debug",
        "ON"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Firmware: Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build/Debug",
        "--parallel"
      ],
      "dependsOn": "Firmware: Configure",
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Firmware: Rebuild",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build/Debug",
        "--clean-first",
        "--parallel"
      ],
      "dependsOn": "Firmware: Configure",
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Firmware: Clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build/Debug",
        "--target",
        "clean"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Firmware: Bootstrap",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/bootstrap_cmake_env.sh",
      "args": [
        "${workspaceFolder}",
        "${workspaceFolder}/build/Debug",
        "Ninja",
        "${workspaceFolder}/cmake/toolchains/arm-none-eabi.cmake",
        "${config:cpr.tools.armToolchainBinDir}",
        "Debug",
        "ON"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
