{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "J-Link Debug (CprSensor)",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "servertype": "jlink",
      "serverpath": "${config:cpr.tools.jlinkGdbServer}",
      "device": "${config:cpr.target.device}",
      "interface": "${config:cpr.target.interface}",
      "executable": "${workspaceFolder}/build/Debug/CprSensor.elf",
      "gdbPath": "${config:cpr.tools.armGdbPath}",
      "armToolchainPath": "${config:cpr.tools.armToolchainBinDir}",
      "runToEntryPoint": "main",
      "preLaunchTask": "Firmware: Build",
      "serverArgs": [
        "-speed",
        "${config:cpr.target.speed}",
        "-port",
        "2331",
        "-swoport",
        "2332",
        "-telnetport",
        "2333"
      ],
      "postLaunchCommands": [
        "monitor reset",
        "monitor halt"
      ],
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "clearSearch": false,
        "decoders": [
          {
            "label": "RTT",
            "port": 0,
            "encoding": "utf8"
          }
        ]
      }
    }
  ]
}
