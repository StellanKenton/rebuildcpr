{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "cmake.generator": "Ninja",
  "cmake.configureOnOpen": true,
  "cmake.buildDirectory": "${workspaceFolder}/build/Debug",
  "cmake.sourceDirectory": "${workspaceFolder}",
  "cmake.preferredGenerators": [
    "Ninja"
  ],
  "cmake.configureSettings": {
    "CMAKE_TOOLCHAIN_FILE": "${workspaceFolder}/cmake/toolchains/arm-none-eabi.cmake",
    "ARM_GNU_TOOLCHAIN_BIN_DIR": "/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin",
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
  },
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build/Debug"
  ],
  "files.associations": {
    "*.ld": "ld"
  },
  "cpr.tools.armToolchainBinDir": "${env:ARM_GNU_TOOLCHAIN_BIN_DIR}",
  "cpr.tools.armGdbPath": "${env:ARM_GNU_TOOLCHAIN_BIN_DIR}/arm-none-eabi-gdb.exe",
  "cpr.tools.jlinkGdbServer": "${env:JLINK_PATH}/JLinkGDBServerCL.exe",
  "cpr.target.device": "STM32F103RE",
  "cpr.target.interface": "SWD",
  "cpr.target.speed": "4000",
  "commands.workspaceCommands": {
    "Cpr Build": {
      "command": "workbench.action.tasks.runTask",
      "args": "Keil: Build",
      "icon": "tools",
      "statusBar": {
        "alignment": "left",
        "text": " Build",
        "name": "Cpr Build",
        "priority": 400,
        "tooltip": "Run the Keil build task in the integrated terminal."
      }
    },
    "Cpr Rebuild": {
      "command": "workbench.action.tasks.runTask",
      "args": "Keil: Rebuild",
      "icon": "refresh",
      "statusBar": {
        "alignment": "left",
        "text": " Rebuild",
        "name": "Cpr Rebuild",
        "priority": 399,
        "tooltip": "Run the Keil rebuild task in the integrated terminal."
      }
    },
    "Cpr Flash": {
      "command": "workbench.action.tasks.runTask",
      "args": "J-Link: Flash",
      "icon": "plug",
      "statusBar": {
        "alignment": "left",
        "text": " Flash",
        "name": "Cpr Flash",
        "priority": 398,
        "tooltip": "Build and flash the target with the J-Link task."
      }
    },
    "Cpr Reset": {
      "command": "workbench.action.tasks.runTask",
      "args": "J-Link: Reset",
      "icon": "debug-restart",
      "statusBar": {
        "alignment": "left",
        "text": " Reset",
        "name": "Cpr Reset",
        "priority": 397,
        "tooltip": "Reset the target with J-Link."
      }
    },
    "Cpr RTT IO": {
      "icon": "terminal",
      "sequence": [
        {
          "command": "workbench.action.tasks.runTask",
          "args": "J-Link: RTT Server"
        },
        {
          "command": "workbench.action.tasks.runTask",
          "args": "J-Link: RTT Terminal",
          "delay": 800
        }
      ],
      "statusBar": {
        "alignment": "left",
        "text": " RTT",
        "name": "Cpr RTT IO",
        "priority": 396,
        "tooltip": "Start the J-Link RTT server, then open the RTT terminal for read and write I/O."
      }
    },
    "Cpr Serial Monitor": {
      "command": "workbench.action.tasks.runTask",
      "args": "Serial: Monitor",
      "icon": "device-mobile",
      "statusBar": {
        "alignment": "left",
        "text": " Serial",
        "name": "Cpr Serial Monitor",
        "priority": 395,
        "tooltip": "Open the UART serial monitor. If needed, VS Code will prompt for the COM port."
      }
    }
  }
}
